using AutoFeed_Backend_DAO.Models;
using AutoFeed_Backend_Repositories.UnitOfWork;
using AutoFeed_Backend_Services.Interfaces;
using System.Collections.Generic;
using System.Threading.Tasks;
using System;
using System.Linq;

namespace AutoFeed_Backend_Services.Services;

public class LargeChickenService : ILargeChickenService
{
    private readonly IUnitOfWork _unitOfWork;

    public LargeChickenService()
    {
        _unitOfWork = new UnitOfWork();
    }

    public LargeChickenService(IUnitOfWork unitOfWork)
    {
        _unitOfWork = unitOfWork;
    }

    private static int CalculateAgeInMonths(DateOnly doB)
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        var ageInMonths = (today.Year - doB.Year) * 12 + (today.Month - doB.Month);
        return Math.Max(0, ageInMonths);
    }

    private void EnrichWithAge(LargeChicken lc)
    {
        if (lc?.Flock != null)
        {
            lc.AgeInMonths = CalculateAgeInMonths(lc.Flock.DoB);
        }
    }

    public async Task<List<LargeChicken>> GetAllAsync()
    {
        var items = await _unitOfWork.LargeChickens.GetAllAsync();
        foreach (var item in items)
        {
            EnrichWithAge(item);
        }
        return items;
    }

    public async Task<List<LargeChicken>> GetActiveAsync()
    {
        var items = await _unitOfWork.LargeChickens.GetActiveAsync();
        foreach (var item in items)
        {
            EnrichWithAge(item);
        }
        return items;
    }

    public async Task<List<LargeChicken>> GetInactiveAsync()
    {
        var items = await _unitOfWork.LargeChickens.GetInactiveAsync();
        foreach (var item in items)
        {
            EnrichWithAge(item);
        }
        return items;
    }

    public async Task<LargeChicken?> GetByIdAsync(int id)
    {
        var item = await _unitOfWork.LargeChickens.GetByIdAsync(id);
        if (item != null)
        {
            EnrichWithAge(item);
        }
        return item;
    }

    public async Task<List<LargeChicken>> SearchAsync(string? name, string? healthStatus, int? flockId, bool includeInactive)
    {
        var items = await _unitOfWork.LargeChickens.SearchAsync(name, healthStatus, flockId, includeInactive);
        foreach (var item in items)
        {
            EnrichWithAge(item);
        }
        return items;
    }

    public async Task<int> CreateAsync(LargeChicken entity)
    {
        entity.IsActive = true;
        _unitOfWork.LargeChickens.PrepareCreate(entity);
        var result = await _unitOfWork.SaveChangesWithTransactionAsync();
        // If save succeeded, EF will populate entity.ChickenLid — return it so callers get the new id
        return result > 0 ? entity.ChickenLid : 0;
    }

    public async Task<bool> UpdateAsync(LargeChicken entity)
    {
        try
        {
            _unitOfWork.LargeChickens.PrepareUpdate(entity);
            var result = await _unitOfWork.SaveChangesWithTransactionAsync();
            return result > 0;
        }
        catch
        {
            return false;
        }
    }

    public async Task<bool> DeleteAsync(int id)
    {
        var entity = await _unitOfWork.LargeChickens.GetByIdAsync(id);
        if (entity == null) return false;

        entity.IsActive = false;
        _unitOfWork.LargeChickens.PrepareUpdate(entity);
        var result = await _unitOfWork.SaveChangesWithTransactionAsync();
        return result > 0;
    }

    public async Task<bool> RestoreAsync(int id)
    {
        var entity = await _unitOfWork.LargeChickens.GetByIdAsync(id);
        if (entity == null) return false;

        entity.IsActive = true;
        _unitOfWork.LargeChickens.PrepareUpdate(entity);
        var result = await _unitOfWork.SaveChangesWithTransactionAsync();
        return result > 0;
    }
}