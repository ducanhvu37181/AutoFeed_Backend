using AutoFeed_Backend.Models.Requests.Flock;
using AutoFeed_Backend.Models.Responses;
using AutoFeed_Backend_Services.Models.Responses;
using System.Collections.Generic;
using System.Threading.Tasks;

namespace AutoFeed_Backend_Services.Interfaces
{
    public interface IFlockService
    {
        Task<IEnumerable<FlockResponse>> GetAllFlocksAsync();
        Task<IEnumerable<FlockResponse>> GetFlocksDashboardAsync(string? searchTerm, int? barnId, string? status);
        Task<FlockResponse?> GetFlockByIdAsync(int id);
        /// <summary>Get active flocks (IsActive == true).</summary>
        Task<IEnumerable<FlockResponse>> GetActiveFlocksAsync();
        /// <summary>Get inactive flocks (IsActive != true).</summary>
        Task<IEnumerable<FlockResponse>> GetInactiveFlocksAsync();
        /// <summary>Get flocks that can be assigned to large barn (age >= 3 months).</summary>
        Task<IEnumerable<FlockResponse>> GetAssignableFlocksAsync();
        /// <summary>Get flocks that cannot be assigned to large barn (age < 3 months).</summary>
        Task<IEnumerable<FlockResponse>> GetUnassignableFlocksAsync();
        /// <summary>Returns flock id with assigned barn info on success, null on failure.</summary>
        Task<CreateFlockResponse?> CreateFlockAsync(FlockCreateRequest request);
        Task<bool> UpdateFlockAsync(FlockUpdateRequest request);
        /// <returns>Success + null error, or failure + message (FK / DB).</returns>
        Task<(bool Success, string? Error)> DeleteFlockAsync(int id);
        Task<bool> UpgradeToLargeChickenAsync(FlockUpgradeRequest request);
    }
}